###> octo-php/symfony-bundle ###
# Memory RSS warning threshold in bytes (default: 100 MB = 104857600)
OCTOP_SYMFONY_MEMORY_WARNING_THRESHOLD=104857600

# Reset duration warning threshold in milliseconds (default: 50)
OCTOP_SYMFONY_RESET_WARNING_MS=50

# Reboot kernel every N requests (0 = disabled)
OCTOP_SYMFONY_KERNEL_REBOOT_EVERY=0
###< octo-php/symfony-bundle ###
